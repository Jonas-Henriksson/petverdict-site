---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';
import { authors } from '../authors';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About ' + siteConfig.siteName,
  description: 'Meet the team behind ' + siteConfig.siteName + ' — independent pet product testing and reviews.',
  publisher: {
    '@type': 'Organization',
    name: siteConfig.siteName,
    url: siteConfig.domain,
  },
};

const teamMembers = Object.values(authors);
---

<BaseLayout title={`About ${siteConfig.siteName}`} description="Meet the veterinary professionals and pet product testers behind PetVerdict's independent reviews of pet food, gear, and technology." schema={aboutSchema}>
  <article class="about-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">About</span>
    </nav>

    <header class="page-header">
      <span class="page-label">About</span>
      <h1>Pet product reviews<br/><em>tested by real pets and their people.</em></h1>
      <div class="header-rule"></div>
    </header>

    <div class="content">
      <section>
        <h2>Our Mission</h2>
        <p>Pet owners deserve better than influencer unboxing videos and Amazon review summaries. PetVerdict tests pet food, supplements, tech gadgets, insurance plans, and grooming tools with the same rigor you would expect from a consumer testing lab — because your pet's health and happiness are not something to guess about.</p>
        <p>Every pet food we review gets ingredient analysis from a veterinary nutritionist. Every gadget gets tested with real animals over weeks, not hours. And every insurance plan gets evaluated against actual claim scenarios, not just premium prices.</p>
      </section>

      <section>
        <h2>Our Team</h2>
        <p class="section-intro">Veterinary professionals, certified technicians, and dedicated pet owners.</p>
        <div class="team-grid">
          {teamMembers.map(member => (
            <div class="team-member">
              <div class="member-avatar">
                {member.image ? (
                  <img src={member.image} alt={member.name} width="56" height="56" style="border-radius: 50%; object-fit: cover; width: 56px; height: 56px;" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                  <span style="display:none">{member.initials}</span>
                ) : (
                  <span>{member.initials}</span>
                )}
              </div>
              <div class="member-info">
                <a href={`/author/${member.slug}`} class="member-name">{member.name}</a>
                <span class="member-title">{member.title}</span>
                <span class="member-creds">{member.credentials}</span>
                <p class="member-bio">{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2>How We Work</h2>
        <p>We purchase all products at retail price and test them with a network of 20+ volunteer pet families across different breeds, sizes, and ages. Pet food reviews include veterinary ingredient analysis and palatability testing. Tech products go through minimum 14-day trials. Insurance plans are evaluated against standardized claim scenarios.</p>
        <p>Read our complete <a href="/how-we-test">testing methodology</a>.</p>
      </section>

      <section>
        <h2>Editorial Independence</h2>
        <p>PetVerdict earns revenue through affiliate links to pet retailers and insurance providers. This funds our testing but never influences scores. We have given poor marks to products from partners and recommended products with no affiliate program. Our pets come first — and so do yours.</p>
        <p>Details in our <a href="/disclosure">affiliate disclosure</a>.</p>
      </section>

      <section class="contact">
        <h2>Get in Touch</h2>
        <p>Have a product you want us to test, a question about a review, or a correction? Email <a href="mailto:hello@petverdict.net">hello@petverdict.net</a>.</p>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .about-page { max-width: var(--max-width); margin: 0 auto; }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--ink-400); margin-bottom: var(--space-xl); }
  .breadcrumb a { color: var(--ink-500); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-950); }
  .sep { color: var(--ink-300); }
  .current { color: var(--ink-400); }
  .page-header { margin-bottom: var(--space-2xl); animation: fadeInUp var(--duration-slow) var(--ease-out) both; }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .page-header h1 { margin-top: var(--space-sm); margin-bottom: var(--space-md); }
  .page-header h1 em { font-style: italic; color: var(--ink-500); }
  .header-rule { height: 2px; width: 48px; background: var(--surface-inverse); }
  .content section { margin-bottom: var(--space-2xl); }
  .content h2 { margin-top: 0; margin-bottom: var(--space-md); padding-top: var(--space-xl); border-top: 1px solid var(--ink-100); }
  .content section:first-child h2 { border-top: none; padding-top: 0; }
  .content p { color: var(--ink-700); line-height: 1.75; margin-bottom: 0.75rem; }
  .section-intro { color: var(--ink-500); margin-bottom: 1.5rem; }
  .team-grid { display: flex; flex-direction: column; gap: 1.5rem; }
  .team-member { display: flex; gap: 1.25rem; padding: 1.25rem 1.5rem; border: 1px solid var(--ink-100); border-radius: var(--border-radius-lg, 10px); background: var(--surface, #fff); transition: border-color 0.15s ease-out; }
  .team-member:hover { border-color: var(--ink-300); }
  .member-avatar { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; border-radius: 50%; background: var(--surface-inverse); color: white; font-weight: 700; font-size: 1rem; letter-spacing: 0.04em; flex-shrink: 0; }
  .member-info { display: flex; flex-direction: column; gap: 0.15rem; }
  .member-name { font-weight: 600; font-size: 1rem; color: var(--ink-950); text-decoration: none; }
  .member-name:hover { text-decoration: underline; text-underline-offset: 2px; }
  .member-title { font-size: 0.85rem; color: var(--ink-500); }
  .member-creds { font-size: 0.8rem; color: var(--ink-400); font-style: italic; }
  .member-bio { font-size: 0.9rem; color: var(--ink-600); line-height: 1.6; margin-top: 0.5rem; }
  .contact a { font-weight: 600; text-decoration: underline; text-underline-offset: 3px; }
  @media (max-width: 640px) { .team-member { flex-direction: column; } }
</style>
