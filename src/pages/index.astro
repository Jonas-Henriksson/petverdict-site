---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../../site.config';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = [...allArticles].sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const latestArticles = [...allArticles]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const TOP_PICKS = [
  { name: 'Shop Amazon Pet', price: null, category: 'All Pet Supplies', slug: 'amazon', tag: 'Top retailer' },
  { name: 'Chewy', price: null, category: 'Food & Treats', slug: 'chewy', tag: 'Best prices' },
  { name: 'Petco', price: null, category: 'Gear & Accessories', slug: 'petco', tag: 'In-store pickup' },
  { name: 'Canada Pet Care', price: null, category: 'Medications & Health', slug: 'canada-pet-care', tag: 'Best value Rx' },
  { name: 'Pet Care Supplies', price: null, category: 'Supplements & Wellness', slug: 'pet-care-supplies', tag: 'Editor tested' },
];

const featuredArticle = sortedArticles[0];
const rankedArticles = sortedArticles.slice(1, 7);
const remainingArticles = sortedArticles.slice(7);
const API_URL = 'https://newsletter.petverdict.net/subscribe';
const SITE_ID = 'petverdict';
const fGradient = 'linear-gradient(135deg, #7c2d12, #ea580c)';
---

<BaseLayout title={`${siteConfig.siteName} — ${siteConfig.tagline}`}>
  <div class="page-layout">

    <!-- LEFT COLUMN: Latest Reviews -->
    <aside class="col-left">
      <div class="panel-header">
        <span class="panel-label">Latest Reviews</span>
      </div>
      <ul class="latest-list">
        {latestArticles.map((article) => (
          <li class="latest-item">
            <a href={`/${article.slug}`} class="latest-link">
              <span class="latest-title">{article.data.title}</span>
              <time
                class="latest-date"
                datetime={new Date(article.data.date).toISOString()}
              >
                {new Date(article.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
            {article.data.category && (
              <span class="latest-cat">{article.data.category}</span>
            )}
          </li>
        ))}
      </ul>
      {allArticles.length > 8 && (
        <a href="/reviews" class="see-all-link">All reviews &rarr;</a>
      )}

      <!-- Methodology note -->
      <div class="methodology-box">
        <p class="methodology-text">Every product is tested with real pets. Not influencer unboxings.</p>
        <a href="/disclosure" class="methodology-cta-link">Our methodology &rarr;</a>
      </div>
    </aside>

    <!-- CENTER COLUMN: Featured hero + ranked grid + subscribe -->
    <main class="col-center">

      <!-- Featured hero -->
      {featuredArticle && (
        <section class="featured-hero">
          <div class="hero-eyebrow">
            <span class="hero-badge">Top Rated</span>
            {featuredArticle.data.category && (
              <span class="hero-category">{featuredArticle.data.category}</span>
            )}
          </div>
          <a href={`/${featuredArticle.slug}`} class="hero-link">
            <h1 class="hero-title">{featuredArticle.data.title}</h1>
          </a>
          {featuredArticle.data.description && (
            <p class="hero-description">{featuredArticle.data.description}</p>
          )}
          <div class="hero-footer">
            <time
              class="hero-date"
              datetime={new Date(featuredArticle.data.date).toISOString()}
            >
              {new Date(featuredArticle.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            {featuredArticle.data.winner && (
              <span class="hero-winner">Winner: <strong>{featuredArticle.data.winner}</strong></span>
            )}
            {featuredArticle.data.score && (
              <span class="hero-score">
                <span class="hero-score-value">{featuredArticle.data.score.toFixed(1)}</span>
                <span class="hero-score-denom">/10</span>
              </span>
            )}
            <a href={`/${featuredArticle.slug}`} class="hero-read-more">Read full review &rarr;</a>
          </div>
        </section>
      )}

      <!-- Subscribe strip -->
      <section class="subscribe-strip">
        <div class="subscribe-copy">
          <strong>Pet gear that actually holds up, tested with real animals.</strong>
          <span class="subscribe-sub">Weekly picks. No fluff. Unsubscribe anytime.</span>
        </div>
        <form class="subscribe-form" data-api={API_URL} data-site={SITE_ID}>
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="subscribe-input"
            aria-label="Email address"
          />
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <p class="subscribe-status" aria-live="polite"></p>
      </section>

      <!-- Ranked reviews grid -->
      {rankedArticles.length > 0 && (
        <section class="rankings-section">
          <div class="section-header">
            <span class="section-label">Top Rankings</span>
            <div class="section-line"></div>
          </div>
          <div class="rankings-grid">
            {rankedArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                  rank={i + 2}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- More reviews -->
      {remainingArticles.length > 0 && (
        <section class="more-section">
          <div class="section-header">
            <span class="section-label">More Reviews</span>
            <div class="section-line"></div>
          </div>
          <div class="more-grid">
            {remainingArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                />
              </div>
            ))}
          </div>
        </section>
      )}
    </main>

    <!-- RIGHT COLUMN: Sticky affiliate picks -->
    <aside class="col-right">
      <div class="panel-header">
        <span class="panel-label">Top pet picks</span>
      </div>
      <ul class="picks-list">
        {TOP_PICKS.map((pick) => (
          <li class="pick-item">
            <a href={`/go/${pick.slug}`} class="pick-link" target="_blank" rel="noopener sponsored">
              <span class="pick-name">{pick.name}</span>
              {pick.tag && <span class="pick-tag">{pick.tag}</span>}
              <span class="pick-category">{pick.category}</span>
              <span class="pick-arrow">Shop &rarr;</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="affiliate-disclosure">
        Affiliate links. We earn a commission at no extra cost to you. Rankings are never influenced by sponsorship.
      </p>
    </aside>

  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLFormElement>('.subscribe-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.nextElementSibling as HTMLParagraphElement | null;
      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!emailInput || !btn) return;

      const email = emailInput.value.trim();
      const apiUrl = form.dataset.api ?? '';
      const siteId = form.dataset.site ?? '';

      btn.textContent = 'Subscribing…';
      btn.disabled = true;

      try {
        const res = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, site: siteId }),
        });
        if (res.ok) {
          if (status) status.textContent = 'You\'re in! Check your inbox.';
          form.reset();
        } else {
          if (status) status.textContent = 'Something went wrong. Please try again.';
        }
      } catch {
        if (status) status.textContent = 'Network error. Please try again.';
      } finally {
        btn.textContent = 'Subscribe';
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  /* ── Page shell ─────────────────────────────────────────────────── */
  .page-layout {
    display: grid;
    grid-template-columns: 240px 1fr 220px;
    grid-template-areas: "left center right";
    gap: var(--space-2xl);
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: var(--space-2xl) 0 var(--space-3xl);
    align-items: start;
  }

  .col-left  { grid-area: left;   }
  .col-center { grid-area: center; }
  .col-right { grid-area: right;  position: sticky; top: var(--space-xl); }

  /* ── Shared panel header ────────────────────────────────────────── */
  .panel-header {
    border-bottom: 2px solid var(--electric);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .panel-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--electric);
  }

  /* ── Left: Latest reviews ───────────────────────────────────────── */
  .latest-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
  }

  .latest-item {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--ink-100);
  }

  .latest-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    color: inherit;
  }

  .latest-link:hover .latest-title { color: var(--electric); }

  .latest-title {
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink-900, #111);
    transition: color 0.15s ease;
  }

  .latest-date {
    font-size: 0.7rem;
    color: var(--ink-400);
  }

  .latest-cat {
    display: inline-block;
    margin-top: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-400);
    background: var(--ink-100);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .see-all-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--electric);
    text-decoration: none;
    margin-bottom: var(--space-xl);
  }

  .see-all-link:hover { text-decoration: underline; }

  .methodology-box {
    margin-top: var(--space-xl);
    padding: var(--space-md);
    border-left: 3px solid var(--electric);
    background: var(--surface, #f8f7f5);
    border-radius: 0 4px 4px 0;
  }

  .methodology-text {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--ink-600, #444);
    margin: 0 0 var(--space-sm);
  }

  .methodology-cta-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-800, #222);
    text-decoration: none;
    border-bottom: 1px solid var(--ink-300);
    padding-bottom: 1px;
  }

  .methodology-cta-link:hover { color: var(--electric); border-color: var(--electric); }

  /* ── Center: Featured hero ──────────────────────────────────────── */
  .featured-hero {
    background: var(--surface-inverse, #0f0f0f);
    border-radius: var(--border-radius-lg, 10px);
    padding: var(--space-2xl);
    margin-bottom: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }

  .featured-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: v-bind(fGradient);
    opacity: 0.12;
    pointer-events: none;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--electric);
    color: white;
    padding: 2px 8px;
    border-radius: 3px;
  }

  .hero-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
  }

  .hero-link { text-decoration: none; }

  .hero-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 var(--space-md);
  }

  .hero-link:hover .hero-title { color: var(--electric); }

  .hero-description {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-400);
    margin: 0 0 var(--space-lg);
    max-width: 600px;
  }

  .hero-footer {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .hero-date { font-size: 0.8rem; color: var(--ink-500); }

  .hero-winner { font-size: 0.85rem; color: var(--ink-400); }
  .hero-winner strong { color: white; font-weight: 600; }

  .hero-score {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-left: auto;
  }

  .hero-score-value {
    font-family: var(--font-display, serif);
    font-size: 2.5rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: white;
  }

  .hero-score-denom { font-size: 0.9rem; color: var(--ink-500); }

  .hero-read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--electric);
    text-decoration: none;
  }

  .hero-read-more:hover { text-decoration: underline; }

  /* ── Subscribe strip ────────────────────────────────────────────── */
  .subscribe-strip {
    background: var(--ink-50, #f5f4f2);
    border: 1px solid var(--ink-200);
    border-radius: var(--border-radius-lg, 10px);
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .subscribe-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 200px;
  }

  .subscribe-copy strong {
    font-size: 0.95rem;
    color: var(--ink-900, #111);
  }

  .subscribe-sub {
    font-size: 0.8rem;
    color: var(--ink-500);
  }

  .subscribe-form {
    display: flex;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .subscribe-input {
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    border: 1px solid var(--ink-300);
    border-radius: 6px;
    background: white;
    color: var(--ink-900, #111);
    width: 200px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .subscribe-input:focus { border-color: var(--electric); }

  .subscribe-btn {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--electric);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .subscribe-btn:hover:not(:disabled) { opacity: 0.88; }
  .subscribe-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .subscribe-status {
    font-size: 0.8rem;
    color: var(--electric);
    margin: 0;
    width: 100%;
    min-height: 1.2em;
  }

  /* ── Section headers ────────────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-400);
    white-space: nowrap;
  }

  .section-line { flex: 1; height: 1px; background: var(--ink-100); }

  /* ── Rankings + more grids ──────────────────────────────────────── */
  .rankings-section,
  .more-section { margin-bottom: var(--space-3xl); }

  .rankings-grid,
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .article-animate { animation: fadeInUp var(--duration-slow, 0.35s) var(--ease-out, ease-out) both; }

  /* ── Right: Affiliate picks ─────────────────────────────────────── */
  .picks-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
  }

  .pick-item {
    border-bottom: 1px solid var(--ink-100);
  }

  .pick-link {
    display: grid;
    grid-template-areas:
      "name arrow"
      "tag  arrow"
      "cat  arrow";
    grid-template-columns: 1fr auto;
    column-gap: var(--space-sm);
    padding: var(--space-sm) 0;
    text-decoration: none;
    color: inherit;
  }

  .pick-link:hover .pick-name { color: var(--electric); }
  .pick-link:hover .pick-arrow { color: var(--electric); }

  .pick-name {
    grid-area: name;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink-900, #111);
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .pick-tag {
    grid-area: tag;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--electric);
  }

  .pick-category {
    grid-area: cat;
    font-size: 0.7rem;
    color: var(--ink-400);
  }

  .pick-arrow {
    grid-area: arrow;
    align-self: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-400);
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .affiliate-disclosure {
    font-size: 0.65rem;
    line-height: 1.5;
    color: var(--ink-400);
    margin-top: var(--space-md);
  }

  /* ── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .page-layout {
      grid-template-columns: 200px 1fr 200px;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 900px) {
    .page-layout {
      grid-template-columns: 1fr;
      grid-template-areas:
        "center"
        "right"
        "left";
    }

    .col-right { position: static; }

    .picks-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0 var(--space-md);
    }

    .pick-item { border-bottom: none; border-top: 1px solid var(--ink-100); }

    .subscribe-strip { flex-direction: column; align-items: flex-start; gap: var(--space-md); }
    .subscribe-form { width: 100%; }
    .subscribe-input { flex: 1; width: auto; min-width: 0; }
  }

  @media (max-width: 600px) {
    .hero-title { font-size: clamp(1.4rem, 5vw, 1.8rem); }
    .rankings-grid, .more-grid { grid-template-columns: 1fr; }
    .hero-footer { gap: var(--space-md); }
    .hero-score { margin-left: 0; }
  }
</style>
